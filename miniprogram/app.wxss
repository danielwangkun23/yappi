/* 全局 CSS 变量和通用样式 - 从 H5 版本迁移 */
page {
  --p: #9B6BFF;
  --pk: #FF6B9D;
  --or: #FF8C42;
  --gn: #6BCB77;
  --bl: #4ECDC4;
  --bg: #FFF8F0;
  --card: #fff;
  --text: #3D2C4E;
  --muted: #9B8FAE;
  --sh: 0 4px 20rpx rgba(155, 107, 255, 0.10);
  --cat-study: #4A90E2;
  --cat-habit: #6BCB77;
  --cat-moral: #FF8C42;
  --cat-sport: #9B6BFF;
  --cat-other: #9B8FAE;
  background: var(--bg);
  font-family: -apple-system, 'PingFang SC', sans-serif;
  color: var(--text);
}

/* 通用按钮 */
.btn-p {
  width: 100%;
  background: linear-gradient(135deg, var(--p), var(--pk));
  color: #fff;
  border: none;
  border-radius: 28rpx;
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.btn-s {
  width: 100%;
  background: #F5F0FF;
  color: var(--p);
  border: none;
  border-radius: 28rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 800;
  margin-top: 16rpx;
}

/* 通用输入框 */
.fi {
  border: 4rpx solid #E8E0F5;
  border-radius: 28rpx;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  width: 100%;
  background: #fff;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 36rpx;
  box-shadow: var(--sh);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 72rpx 40rpx;
  color: var(--muted);
}
.es-icon { font-size: 88rpx; display: block; margin-bottom: 20rpx; }
.es-text { font-size: 28rpx; font-weight: 700; }
.es-sub { font-size: 24rpx; margin-top: 6rpx; }

/* Toast 提示 */
.toast {
  position: fixed;
  bottom: 176rpx;
  left: 50%;
  transform: translateX(-50%);
  background: var(--text);
  color: #fff;
  padding: 20rpx 44rpx;
  border-radius: 52rpx;
  font-size: 24rpx;
  font-weight: 700;
  z-index: 300;
  white-space: nowrap;
}

/* 分类颜色标签 */
.cat-tag {
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  color: #fff;
}

/* 管理卡片 */
.mg-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  box-shadow: var(--sh);
  margin-bottom: 14rpx;
}
.mg-emoji {
  font-size: 40rpx;
  width: 72rpx;
  height: 72rpx;
  background: #F5F0FF;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.mg-info { flex: 1; min-width: 0; }
.mg-name { font-size: 26rpx; font-weight: 800; color: var(--text); }
.mg-meta { font-size: 20rpx; font-weight: 600; color: var(--muted); margin-top: 2rpx; }
.mg-acts { display: flex; gap: 10rpx; }
.ib {
  width: 56rpx; height: 56rpx; border-radius: 16rpx;
  border: none; background: #F5F0FF; font-size: 26rpx;
  display: flex; align-items: center; justify-content: center;
}
.db {
  width: 56rpx; height: 56rpx; border-radius: 16rpx;
  border: none; background: #FFF0F0; color: #FF6B6B; font-size: 26rpx;
  display: flex; align-items: center; justify-content: center;
}

/* 弹窗底部面板 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(61, 44, 78, 0.5);
  z-index: 100;
}
.popup-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 52rpx 52rpx 0 0;
  padding: 40rpx 36rpx calc(40rpx + env(safe-area-inset-bottom));
  max-height: 88vh;
  overflow-y: auto;
  z-index: 101;
}
.popup-handle {
  width: 72rpx;
  height: 8rpx;
  background: #E0D6F5;
  border-radius: 4rpx;
  margin: 0 auto 32rpx;
}
.popup-title {
  font-size: 34rpx;
  font-weight: 900;
  color: var(--text);
  margin-bottom: 28rpx;
}

/* 标签选择器 pill */
.pill-row { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 24rpx; }
.pill {
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  border: 4rpx solid #E8E0F5;
  background: #F5F0FF;
  font-size: 24rpx;
  font-weight: 800;
  color: var(--muted);
}
.pill.sel {
  border-color: var(--p);
  background: #EDE0FF;
  color: var(--p);
}

/* 表单标签 */
.fl-label {
  font-size: 24rpx;
  font-weight: 800;
  color: var(--text);
  margin-bottom: 10rpx;
  display: block;
}
