.page { min-height: 100vh; background: var(--bg); padding-bottom: 200rpx; }

.report-hdr {
  background: linear-gradient(135deg, #3D2C4E, #6B4E8A);
  padding: 88rpx 36rpx 40rpx;
}
.rpt-child { color: rgba(255,255,255,0.7); font-size: 26rpx; font-weight: 700; margin-bottom: 6rpx; }
.rpt-title { color: #fff; font-size: 40rpx; font-weight: 900; }

.month-nav {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 36rpx 0;
}
.mn-btn {
  width: 64rpx; height: 64rpx; border-radius: 20rpx;
  background: #fff; font-size: 36rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
  color: var(--p);
}
.mn-label { font-size: 32rpx; font-weight: 900; color: var(--text); }

/* Tab */
.tab-row {
  display: flex; margin: 24rpx 36rpx 0;
  background: #fff; border-radius: 24rpx;
  padding: 8rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.tab-item {
  flex: 1; text-align: center; padding: 18rpx 0;
  font-size: 26rpx; font-weight: 700; color: var(--muted);
  border-radius: 18rpx;
}
.tab-item.active {
  background: var(--p); color: #fff;
}

/* 统计卡片 */
.stat-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 20rpx; margin: 24rpx 36rpx 0;
}
.stat-card {
  background: #fff; border-radius: 32rpx;
  padding: 28rpx 20rpx; box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
  text-align: center;
}
.stat-icon { font-size: 36rpx; margin-bottom: 8rpx; }
.stat-num { font-size: 48rpx; font-weight: 900; color: var(--p); line-height: 1; }
.stat-unit { font-size: 24rpx; font-weight: 700; }
.stat-lbl { font-size: 22rpx; font-weight: 600; color: var(--muted); margin-top: 6rpx; }

.report-card {
  background: #fff; border-radius: 36rpx;
  margin: 24rpx 36rpx 0; padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}
.rc-title { font-size: 28rpx; font-weight: 900; color: var(--text); margin-bottom: 28rpx; }

/* 分类进度 */
.bm-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 24rpx; }
.bm-cat {
  width: 72rpx; height: 72rpx; border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; flex-shrink: 0;
}
.bm-info { flex: 1; }
.bm-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.bm-name { font-size: 26rpx; font-weight: 800; color: var(--text); }
.bm-nums { font-size: 22rpx; font-weight: 700; color: var(--muted); }
.bm-bar-wrap { height: 14rpx; background: #F0E8FF; border-radius: 8rpx; overflow: hidden; }
.bm-bar { height: 100%; border-radius: 8rpx; transition: width 0.3s; }

/* 趋势图 */
.trend-canvas { width: 100%; height: 120px; display: block; }

/* 流水 */
.ledger-item {
  display: flex; align-items: center; gap: 20rpx;
  padding: 20rpx 0; border-bottom: 2rpx solid #F8F5FF;
}
.ledger-item:last-child { border-bottom: none; }
.ledger-icon {
  width: 72rpx; height: 72rpx; border-radius: 20rpx;
  background: #F5F0FF; font-size: 36rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.ledger-info { flex: 1; }
.ledger-title { font-size: 28rpx; font-weight: 800; color: var(--text); }
.ledger-date { font-size: 22rpx; color: var(--muted); margin-top: 4rpx; }
.ledger-amount { font-size: 30rpx; font-weight: 900; flex-shrink: 0; }
.ledger-amount.earn { color: var(--gn); }
.ledger-amount.spend { color: var(--pk); }

.no-data { color: var(--muted); font-size: 24rpx; font-weight: 600; padding: 20rpx 0; text-align: center; }
