.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #9B6BFF, #FF6B9D);
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 80rpx 48rpx 48rpx;
}

.card {
  background: #fff;
  border-radius: 56rpx;
  padding: 56rpx 44rpx;
  width: 100%;
  box-shadow: 0 40rpx 120rpx rgba(0,0,0,0.15);
}

.step-label {
  font-size: 22rpx;
  font-weight: 800;
  color: var(--p);
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 8rpx;
}

.wiz-title { font-size: 38rpx; font-weight: 900; color: var(--text); margin-bottom: 8rpx; }
.wiz-sub { font-size: 24rpx; font-weight: 600; color: var(--muted); margin-bottom: 36rpx; }

.fi {
  border: 4rpx solid #E8E0F5;
  border-radius: 28rpx;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  width: 100%;
  background: #fff;
  margin-bottom: 24rpx;
}

.av-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
  margin-bottom: 28rpx;
}
.av-opt {
  aspect-ratio: 1;
  border-radius: 22rpx;
  border: 4rpx solid #E8E0F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background: #F8F5FF;
}
.av-opt.sel { border-color: var(--p); background: #F0E8FF; }

.tpl-cats {
  white-space: nowrap;
  margin-bottom: 20rpx;
}
.tpl-cat-btn {
  display: inline-block;
  padding: 10rpx 22rpx;
  border-radius: 32rpx;
  background: #EDE8F8;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 800;
  margin-right: 10rpx;
}
.tpl-cat-btn.active { background: var(--p); color: #fff; }

.tpl-list { max-height: 560rpx; margin-bottom: 24rpx; }
.tpl-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  border: 4rpx solid #EDE8F8;
  background: #F8F5FF;
  margin-bottom: 14rpx;
}
.tpl-item.sel { border-color: var(--p); background: #F0E8FF; }
.tpl-emoji {
  font-size: 40rpx;
  width: 68rpx;
  height: 68rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.tpl-info { flex: 1; }
.tpl-name { font-size: 26rpx; font-weight: 800; color: var(--text); }
.tpl-meta { font-size: 20rpx; font-weight: 600; color: var(--muted); margin-top: 4rpx; }
.tpl-check { font-size: 32rpx; }

.sel-count { font-size: 22rpx; color: var(--muted); font-weight: 600; margin-bottom: 20rpx; text-align: center; }

.btn-p {
  width: 100%;
  background: linear-gradient(135deg, var(--p), var(--pk));
  color: #fff;
  border: none;
  border-radius: 28rpx;
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: 800;
}
.btn-s {
  width: 100%;
  background: #F5F0FF;
  color: var(--p);
  border: none;
  border-radius: 28rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 800;
  margin-top: 16rpx;
}
